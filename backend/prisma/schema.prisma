generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
url      = env("DATABASE_URL")
}

model Country {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  nameNative  String
  flag        String
  language    String
  currency    String
  timezone    String   @default("Asia/Tokyo")
  themeColor  String   @default("#006A4E")
  isActive    Boolean  @default(true)
  users       User[]
  vendors     Vendor[]
  products    Product[]
  banners     Banner[]
  @@map("countries")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  phone           String?
  firstName       String
  lastName        String
  firstNameNative String?
  countryId       String
  country         Country   @relation(fields: [countryId], references: [id])
  language        String    @default("en")
  role            UserRole  @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  preferences     Json?
  emailVerified   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customer        Customer?
  vendor          Vendor?
  addresses       Address[]
  notifications   Notification[]
  @@map("users")
}

model Customer {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  reviews     Review[]
  wishlist    WishlistItem[]
  cartItems   CartItem[]
  @@map("customers")
}

model Vendor {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String
  businessNameNative String?
  businessType    BusinessType
  description     String?      @db.Text
  descriptionNative String?    @db.Text
  countryId       String
  country         Country      @relation(fields: [countryId], references: [id])
  email           String
  phone           String
  address         String
  city            String
  zipCode         String
  logo            String?
  coverImage      String?
  status          VendorStatus @default(PENDING)
  verifiedAt      DateTime?
  documents       Json?
  commissionRate  Decimal      @default(10.00) @db.Decimal(5, 2)
  bankAccount     Json?
  totalSales      Decimal      @default(0) @db.Decimal(15, 2)
  balance         Decimal      @default(0) @db.Decimal(15, 2)
  isActive        Boolean      @default(true)
  shippingZones   Json?
  products        Product[]
  orders          Order[]
  reviews         Review[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  @@map("vendors")
}

model Product {
  id              String        @id @default(uuid())
  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name            String
  nameNative      String?
  slug            String        @unique
  description     String?       @db.Text
  descriptionNative String?     @db.Text
  countryId       String
  country         Country       @relation(fields: [countryId], references: [id])
  targetCountries Json          // Changed from String[] to Json
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  subcategoryId   String?
  tags            Json          // Changed from String[] to Json
  basePrice       Decimal       @db.Decimal(10, 2)
  salePrice       Decimal?      @db.Decimal(10, 2)
  costPrice       Decimal?      @db.Decimal(10, 2)
  currency        String        @default("JPY")
  sku             String        @unique
  barcode         String?
  quantity        Int           @default(0)
  lowStockThreshold Int         @default(10)
  attributes      Json?
  variants        ProductVariant[]
  images          ProductImage[]
  weight          Decimal?      @db.Decimal(8, 2)
  dimensions      Json?
  isHalal         Boolean       @default(false)
  isVegetarian    Boolean       @default(false)
  spiceLevel      Int?
  status          ProductStatus @default(DRAFT)
  featured        Boolean       @default(false)
  viewCount       Int           @default(0)
  salesCount      Int           @default(0)
  rating          Decimal       @default(0) @db.Decimal(3, 2)
  reviewCount     Int           @default(0)
  orderItems      OrderItem[]
  reviews         Review[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([vendorId])
  @@index([countryId])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@map("products")
}

model ProductVariant {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String    @unique
  attributes  Json
  price       Decimal   @db.Decimal(10, 2)
  quantity    Int       @default(0)
  isActive    Boolean   @default(true)
  @@map("product_variants")
}

model ProductImage {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String
  alt         String?
  sortOrder   Int       @default(0)
  isPrimary   Boolean   @default(false)
  @@map("product_images")
}

model Category {
  id          String    @id @default(uuid())
  parentId    String?
  parent      Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  name        String
  nameNative  String?
  slug        String    @unique
  icon        String?
  isActive    Boolean   @default(true)
  products    Product[]
  @@map("categories")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  vendorId        String
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  subtotal        Decimal     @db.Decimal(10, 2)
  taxAmount       Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  items           OrderItem[]
  shippingAddress Json
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?
  transactionId   String?
  status          OrderStatus   @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([customerId])
  @@index([vendorId])
  @@map("orders")
}

model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  totalPrice  Decimal   @db.Decimal(10, 2)
  productName String
  productImage String?
  @@map("order_items")
}

model CartItem {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int       @default(1)
  variantId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@unique([customerId, productId, variantId])
  @@map("cart_items")
}

model WishlistItem {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  @@unique([customerId, productId])
  @@map("wishlist_items")
}

model Review {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id])
  orderId     String?
  rating      Int
  title       String?
  comment     String?   @db.Text
  images      Json      // Changed from String[] to Json
  isVerified  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  @@unique([customerId, productId])
  @@map("reviews")
}

model Banner {
  id          String    @id @default(uuid())
  countryId   String
  country     Country   @relation(fields: [countryId], references: [id])
  title       String
  titleNative String?
  subtitle    String
  image       String
  bgColor     String
  cta         String
  ctaNative   String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  @@map("banners")
}

model Address {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AddressType @default(SHIPPING)
  isDefault   Boolean     @default(false)
  name        String
  phone       String
  postalCode  String
  prefecture  String
  city        String
  address     String
  building    String?
  createdAt   DateTime    @default(now())
  @@map("addresses")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String    @db.Text
  data        Json?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  @@map("notifications")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum BusinessType {
  INDIVIDUAL
  CORPORATION
  PARTNERSHIP
}

enum VendorStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY
  PAYPAY
  KONBINI
  PAYPAL
}

enum AddressType {
  SHIPPING
  BILLING
  BOTH
}

enum NotificationType {
  ORDER
  PAYMENT
  SHIPPING
  PROMOTION
  SYSTEM
  VENDOR
}
